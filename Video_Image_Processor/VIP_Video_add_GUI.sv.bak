always @(posedge clk) begin
    CHINA_0[0 ]  <= 128'h00000000000000000000000000000000;
    CHINA_0[1 ]  <= 128'h00000000000000000000000000100000;
    CHINA_0[2 ]  <= 128'h00101000000000800080000000180000;
    CHINA_0[3 ]  <= 128'h001C1C0001FFFFC000E0000000380000;
    CHINA_0[4 ]  <= 128'h001818100181808000C0000000301800;
    CHINA_0[5 ]  <= 128'h001818380181808001800000007FFC00;
